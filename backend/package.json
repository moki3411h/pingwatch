{
  "name": "pingwatch-backend",
  "version": "1.0.0",
  "description": "API health monitoring platform — backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles",
    "test:coverage": "NODE_ENV=test jest --coverage --runInBand --forceExit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFiles": ["dotenv/config"]
  }
}
